// Prisma Schema for Connect2Kehilla
// Database: PostgreSQL (Neon via Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// БИЗНЕСЫ (Businesses)
// ============================================
model Business {
  id            String   @id @default(cuid())
  name          String
  phone         String
  categoryRaw   String?
  categories    String[]

  // Тип листинга
  listingType   ListingType @default(BUSINESS)
  description   String?
  hoursOfWork   String?
  priceFrom     String?  // "from $50/hr"

  // Локация
  zipCode       String?
  area          String?
  city          String?
  state         String   @default("NY")

  // Контакты
  address       String?
  email         String?
  website       String?
  fax           String?

  // Статус и монетизация
  status        BusinessStatus @default(FREE)
  trialEndsAt   DateTime?

  // Статистика
  leadCount     Int      @default(0)
  lastLeadAt    DateTime?

  // Мета
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isActive      Boolean  @default(true)

  // Связи
  leads         Lead[]
  listings      Listing[]

  @@index([zipCode])
  @@index([categories])
  @@index([status])
  @@index([area])
}

enum ListingType {
  BUSINESS  // store, restaurant, office
  SERVICE   // individual: plumber, tutor, driver
}

enum BusinessStatus {
  FREE
  STANDARD    // $30/8 days
  PREMIUM     // $50/8 days
  SPECIALS    // $40/8 days
  AD_BOOST    // $7.99/8 days
  SUSPENDED
}

// ============================================
// ПЛАТНЫЕ ЛИСТИНГИ (Paid Listings)
// ============================================
model Listing {
  id              String      @id @default(cuid())
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id])
  plan            ListingPlan
  price           Float
  paidAt          DateTime    @default(now())
  expiresAt       DateTime    // paidAt + 8 days
  isActive        Boolean     @default(true)
  squarePaymentId String?
  createdAt       DateTime    @default(now())

  @@index([businessId])
  @@index([expiresAt])
  @@index([isActive])
}

enum ListingPlan {
  STANDARD
  PREMIUM
  SPECIALS
  AD_BOOST
}

// ============================================
// ВАКАНСИИ (Jobs)
// ============================================
model Job {
  id          String      @id @default(cuid())
  title       String
  description String
  category    String
  area        String?
  zipCode     String?
  phone       String
  salary      String?
  type        JobType
  plan        ListingPlan @default(STANDARD)
  paidAt      DateTime    @default(now())
  expiresAt   DateTime
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  @@index([area])
  @@index([category])
  @@index([expiresAt])
  @@index([type])
}

enum JobType {
  SEEKING   // looking for work
  OFFERING  // hiring
}

// ============================================
// ПОДПИСКИ НА ВАКАНСИИ (Job Subscriptions)
// ============================================
model JobSubscription {
  id          String   @id @default(cuid())
  phoneHash   String
  zipCode     String?
  area        String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([phoneHash])
  @@index([area])
  @@index([zipCode])
}

// ============================================
// ПОЛЬЗОВАТЕЛИ (анонимизированные)
// ============================================
model User {
  id            String   @id @default(cuid())
  phoneHash     String   @unique
  defaultZip    String?
  defaultArea   String?
  isBlocked     Boolean  @default(false)
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  queries       Query[]
  leads         Lead[]

  @@index([phoneHash])
}

// ============================================
// ЗАПРОСЫ (Query Log)
// ============================================
model Query {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  rawMessage     String
  parsedCategory String?
  parsedZip      String?
  parsedArea     String?
  parsedIntent   QueryIntent @default(SEARCH)
  responseText   String?
  businessCount  Int         @default(0)
  createdAt      DateTime    @default(now())
  processedAt    DateTime?
  isShabbat      Boolean     @default(false)
  leads          Lead[]

  @@index([userId])
  @@index([createdAt])
}

enum QueryIntent {
  SEARCH
  HELP
  STOP
  INFO
  SPECIALS
  JOBS
  UNKNOWN
}

// ============================================
// ЛИДЫ (выданные контакты)
// ============================================
model Lead {
  id            String   @id @default(cuid())
  queryId       String
  query         Query    @relation(fields: [queryId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  position      Int
  createdAt     DateTime @default(now())

  @@index([businessId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// НАСТРОЙКИ ШАББАТА
// ============================================
model ShabbatSchedule {
  id             String   @id @default(cuid())
  zipCode        String   @unique
  timezone       String   @default("America/New_York")
  candleLighting DateTime
  havdalah       DateTime
  updatedAt      DateTime @updatedAt
}
