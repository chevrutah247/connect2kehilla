// Prisma Schema for Connect2Kehilla
// Database: PostgreSQL (Neon via Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// БИЗНЕСЫ (Businesses)
// ============================================
model Business {
  id            String   @id @default(cuid())
  name          String
  phone         String
  categoryRaw   String?
  categories    String[]

  // Тип листинга
  listingType   ListingType @default(BUSINESS)
  description   String?
  hoursOfWork   String?
  priceFrom     String?  // "from $50/hr"

  // Локация
  zipCode       String?
  area          String?
  city          String?
  state         String   @default("NY")

  // Контакты
  address       String?
  email         String?
  website       String?
  fax           String?

  // Статус и монетизация
  status        BusinessStatus @default(FREE)
  trialEndsAt   DateTime?

  // Статистика
  leadCount     Int      @default(0)
  lastLeadAt    DateTime?

  // Мета
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  isActive      Boolean  @default(true)

  // Approval workflow — web submissions need admin review before going live
  approvalStatus  ApprovalStatus @default(APPROVED)  // default APPROVED so existing rows unaffected
  submittedVia    String?                             // "web", "sms", "import", "admin"
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  // Связи
  leads         Lead[]
  listings      Listing[]

  @@index([zipCode])
  @@index([categories])
  @@index([status])
  @@index([area])
  @@index([approvalStatus])
}

// Approval status for user-submitted records
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ListingType {
  BUSINESS  // store, restaurant, office
  SERVICE   // individual: plumber, tutor, driver
}

enum BusinessStatus {
  FREE
  STANDARD    // $30/8 days
  PREMIUM     // $50/8 days
  SPECIALS    // $40/8 days
  AD_BOOST    // $7.99/8 days
  SUSPENDED
}

// ============================================
// ПЛАТНЫЕ ЛИСТИНГИ (Paid Listings)
// ============================================
model Listing {
  id              String      @id @default(cuid())
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id])
  plan            ListingPlan
  price           Float
  paidAt          DateTime    @default(now())
  expiresAt       DateTime    // paidAt + 8 days
  isActive        Boolean     @default(true)
  squarePaymentId String?
  createdAt       DateTime    @default(now())

  @@index([businessId])
  @@index([expiresAt])
  @@index([isActive])
}

enum ListingPlan {
  STANDARD
  PREMIUM
  SPECIALS
  AD_BOOST
}

// ============================================
// ВАКАНСИИ (Jobs)
// ============================================
model Job {
  id          String      @id @default(cuid())
  title       String
  description String
  category    String
  area        String?
  zipCode     String?
  phone       String
  salary      String?
  type        JobType
  plan        ListingPlan @default(STANDARD)
  paidAt      DateTime    @default(now())
  expiresAt   DateTime
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  @@index([area])
  @@index([category])
  @@index([expiresAt])
  @@index([type])
}

enum JobType {
  SEEKING   // looking for work
  OFFERING  // hiring
}

// ============================================
// ПОДПИСКИ НА ВАКАНСИИ (Job Subscriptions)
// ============================================
model JobSubscription {
  id          String   @id @default(cuid())
  phoneHash   String
  zipCode     String?
  area        String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([phoneHash])
  @@index([area])
  @@index([zipCode])
}

// ============================================
// РАБОТНИКИ "НА ПОДХВАТЕ" (Day Workers)
// ============================================
model Worker {
  id          String   @id @default(cuid())
  phone       String   @unique  // real phone — they opted in from their own number
  phoneHash   String             // for lookup by phoneHash
  category    String             // "driver", "mover", "babysitter"
  area        String?            // "Williamsburg"
  zipCode     String?
  description String?            // skills, experience, availability
  language    String   @default("en") // en, he, yi — registration language
  expiresAt   DateTime           // +30 days from registration
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([area])
  @@index([expiresAt])
  @@index([phoneHash])
  @@index([isActive])
}

// ============================================
// ПОЛЬЗОВАТЕЛИ (анонимизированные)
// ============================================
model User {
  id            String   @id @default(cuid())
  phoneHash     String   @unique
  phone         String?  @unique                   // Raw E.164 phone — enables outbound broadcasts
  defaultZip    String?
  defaultArea   String?
  isBlocked     Boolean  @default(false)           // STOP flag — excluded from all broadcasts
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  queries       Query[]
  leads         Lead[]
  broadcasts    BroadcastRecipient[]

  @@index([phoneHash])
  @@index([phone])
}

// ============================================
// ЗАПРОСЫ (Query Log)
// ============================================
model Query {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  rawMessage     String
  parsedCategory String?
  parsedZip      String?
  parsedArea     String?
  parsedIntent   QueryIntent @default(SEARCH)
  responseText   String?
  businessCount  Int         @default(0)
  createdAt      DateTime    @default(now())
  processedAt    DateTime?
  isShabbat      Boolean     @default(false)
  leads          Lead[]

  @@index([userId])
  @@index([createdAt])
}

enum QueryIntent {
  SEARCH
  HELP
  STOP
  INFO
  SPECIALS
  JOBS
  UNKNOWN
}

// ============================================
// ЛИДЫ (выданные контакты)
// ============================================
model Lead {
  id            String   @id @default(cuid())
  queryId       String
  query         Query    @relation(fields: [queryId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  position      Int
  createdAt     DateTime @default(now())

  @@index([businessId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// НАСТРОЙКИ ШАББАТА
// ============================================
model ShabbatSchedule {
  id             String   @id @default(cuid())
  zipCode        String   @unique
  timezone       String   @default("America/New_York")
  candleLighting DateTime
  havdalah       DateTime
  updatedAt      DateTime @updatedAt
}

// ============================================
// ЗАПРОСЫ О ПОМОЩИ (Tzedaka / Charity)
// ============================================
model CharityRequest {
  id           String   @id @default(cuid())
  name         String                        // requester's name
  phone        String                        // contact phone
  zipCode      String?
  area         String?
  description  String                        // what they need help with
  amount       String?                       // "$500" or "$1,000/mo"
  paymentInfo  String?                       // Zelle / CashApp / Venmo / etc
  isActive     Boolean  @default(true)
  expiresAt    DateTime                      // 30 days from posting
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Approval workflow
  approvalStatus  ApprovalStatus @default(APPROVED)
  submittedVia    String?
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?

  @@index([zipCode])
  @@index([area])
  @@index([isActive])
  @@index([expiresAt])
  @@index([approvalStatus])
}

// ============================================
// МАССОВЫЕ РАССЫЛКИ (SMS broadcasts)
// ============================================
model Broadcast {
  id          String               @id @default(cuid())
  message     String
  segment     String                              // e.g. "category:plumber,zip:11213" or "all"
  sent        Int                  @default(0)
  failed      Int                  @default(0)
  skipped     Int                  @default(0)   // blocked users
  createdAt   DateTime             @default(now())
  createdBy   String?                             // admin identifier
  recipients  BroadcastRecipient[]

  @@index([createdAt])
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcastId String
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  phone       String                         // snapshot of raw phone at send time
  status      String                         // "sent" | "failed" | "skipped"
  twilioSid   String?                        // Twilio message SID for tracking
  error       String?                        // failure reason if any
  sentAt      DateTime  @default(now())

  @@index([broadcastId])
  @@index([userId])
  @@index([status])
}
